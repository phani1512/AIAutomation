  {
    "action": "Dynamic Content Wait",
    "description": "User waits for dynamic content to load",
    "steps": [
      {
        "step": 1,
        "action": "click",
        "code": "driver.findElement(By.id(\"loadDataBtn\")).click();",
        "element_type": "button",
        "locator": "By.id(\"loadDataBtn\")",
        "prompt": "click load data button"
      },
      {
        "step": 2,
        "action": "wait",
        "code": "new WebDriverWait(driver, Duration.ofSeconds(15)).until(ExpectedConditions.presenceOfElementLocated(By.className(\"dataRow\")));",
        "element_type": "div",
        "locator": "By.className(\"dataRow\")",
        "prompt": "wait for data to load"
      },
      {
        "step": 3,
        "action": "verify",
        "code": "List<WebElement> rows = driver.findElements(By.className(\"dataRow\")); assert rows.size() > 0;",
        "element_type": "div",
        "locator": "By.className(\"dataRow\")",
        "prompt": "verify data rows exist"
      }
    ],
    "pattern_type": "ajax_wait"
  },
  {
    "action": "Table Data Extraction",
