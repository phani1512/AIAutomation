  {
    "action": "Modal Dialog Interaction",
    "description": "User interacts with modal popup",
    "steps": [
      {
        "step": 1,
        "action": "click",
        "code": "driver.findElement(By.id(\"openModal\")).click();",
        "element_type": "button",
        "locator": "By.id(\"openModal\")",
        "prompt": "click open modal button"
      },
      {
        "step": 2,
        "action": "wait",
        "code": "new WebDriverWait(driver, Duration.ofSeconds(10)).until(ExpectedConditions.visibilityOfElementLocated(By.id(\"modal\")));",
        "element_type": "div",
        "locator": "By.id(\"modal\")",
        "prompt": "wait for modal to appear"
      },
      {
        "step": 3,
        "action": "sendKeys",
        "code": "driver.findElement(By.id(\"modalInput\")).sendKeys(\"{TEXT}\");",
        "element_type": "input",
        "locator": "By.id(\"modalInput\")",
        "value": "{TEXT}",
        "prompt": "enter {TEXT} in modal input"
      },
      {
        "step": 4,
        "action": "click",
        "code": "driver.findElement(By.id(\"confirmBtn\")).click();",
        "element_type": "button",
        "locator": "By.id(\"confirmBtn\")",
        "prompt": "click confirm button"
      }
    ],
    "pattern_type": "modal_interaction"
  },
  {
    "action": "Tab Navigation",
    "description": "User navigates between tabs",
    "steps": [
      {
        "step": 1,
        "action": "click",
        "code": "driver.findElement(By.linkText(\"Open New Tab\")).click();",
        "element_type": "a",
        "locator": "By.linkText(\"Open New Tab\")",
        "prompt": "click open new tab link"
      },
      {
        "step": 2,
        "action": "switch",
        "code": "String originalWindow = driver.getWindowHandle(); Set<String> handles = driver.getWindowHandles(); for(String handle : handles) { if(!handle.equals(originalWindow)) { driver.switchTo().window(handle); } }",
        "element_type": null,
        "locator": null,
        "prompt": "switch to new tab"
      }
    ],
    "pattern_type": "window_switching"
  },
