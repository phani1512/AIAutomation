  {
    "action": "Hover Menu Navigation",
    "description": "User hovers over menu to reveal submenu and clicks",
    "steps": [
      {
        "step": 1,
        "action": "hover",
        "code": "WebElement menu = driver.findElement(By.id(\"mainMenu\")); new Actions(driver).moveToElement(menu).perform();",
        "element_type": "div",
        "locator": "By.id(\"mainMenu\")",
        "prompt": "hover over main menu"
      },
      {
        "step": 2,
        "action": "wait",
        "code": "new WebDriverWait(driver, Duration.ofSeconds(5)).until(ExpectedConditions.visibilityOfElementLocated(By.id(\"subMenu\")));",
        "element_type": "div",
        "locator": "By.id(\"subMenu\")",
        "prompt": "wait for submenu to appear"
      },
      {
        "step": 3,
        "action": "click",
        "code": "driver.findElement(By.id(\"subMenuItem\")).click();",
        "element_type": "a",
        "locator": "By.id(\"subMenuItem\")",
        "prompt": "click submenu item"
      }
    ],
    "pattern_type": "hover_navigation"
  },
