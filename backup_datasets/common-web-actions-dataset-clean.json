        "prompt": "find data table"
      },
      {
        "step": 2,
        "action": "extract",
        "code": "List<WebElement> rows = table.findElements(By.tagName(\"tr\")); for(WebElement row : rows) { List<WebElement> cells = row.findElements(By.tagName(\"td\")); }",
        "element_type": "tr",
        "locator": "By.tagName(\"tr\")",
        "prompt": "extract table rows"
      }
    ],
    "pattern_type": "table_extraction"
